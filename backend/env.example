# Server
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://ems_user:ems_password@localhost:5432/ems_db?schema=public"

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Seed admin (used by prisma/seed.ts)
SEED_SUPER_ADMIN_EMAIL=admin@ems.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
